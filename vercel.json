{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.7.0"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "^/Admin_panel$",
      "dest": "/Admin_panel.php"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.php"
    }
  ]
}
