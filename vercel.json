{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.6.0"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "^/Admin_panel$",
      "dest": "/Admin_panel.php"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.php"
    }
  ],
  "functions": {
    "*.php": {
      "runtime": "nodejs20.x"
    }
  }
}
