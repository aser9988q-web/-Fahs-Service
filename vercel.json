{
  "version": 2,
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.6.0" },
    "*.php": { "runtime": "vercel-php@0.6.0" }
  },
  "routes": [
    { "src": "/Admin_panel", "dest": "/Admin_panel.php" },
    { "src": "/otp", "dest": "/otp.php" },
    { "src": "/payment", "dest": "/payment.php" },
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
